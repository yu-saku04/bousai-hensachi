{
  "name": "bousai-hensachi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "convert:data": "tsx scripts/csv-to-json.ts",
    "convert:gsi-shelters": "tsx scripts/converters/convert-gsi-shelters.ts",
    "fetch:estat-population-2020": "tsx scripts/fetchers/fetch-estat-population-2020.ts",
    "convert:estat-population-2020": "tsx scripts/converters/convert-estat-population-2020.ts",
    "master:generate": "tsx scripts/generate-national-master.ts --input data/raw/national/municipalities.csv --output data/master/municipalities-base.json --base data/master/municipalities-base.json",
    "import:shelters": "tsx scripts/importers/import-shelters.ts",
    "import:shelters:national": "tsx scripts/importers/import-shelters.ts --input data/raw/national/shelters.csv --output data/processed/shelters.json",
    "import:population": "tsx scripts/importers/import-population.ts",
    "merge:data": "tsx scripts/merge-datasets.ts",
    "merge:data:strict": "tsx scripts/merge-datasets.ts --strict",
    "validate:data": "tsx scripts/validate-datasets.ts",
    "data:build": "npm run import:shelters && npm run merge:data:strict && npm run validate:data -- --strict",
    "data:build:loose": "npm run import:shelters && npm run merge:data && npm run validate:data",
    "data:build:national": "npm run master:generate && npm run import:shelters:national && npm run merge:data:strict && npm run validate:data -- --strict",
    "score:shelter-v1": "tsx scripts/scoring/score-shelter-sufficiency-v1.ts --dry-run",
    "fetch:estat-aging-2020": "tsx scripts/fetchers/fetch-estat-aging-2020.ts",
    "convert:estat-aging-2020": "tsx scripts/converters/convert-estat-aging-2020.ts",
    "import:aging": "tsx scripts/importers/import-aging.ts",
    "score:aging-v1": "tsx scripts/scoring/score-aging-v1.ts --dry-run",
    "fetch:estat-household-2020": "tsx scripts/fetchers/fetch-estat-household-2020.ts",
    "convert:estat-household-2020": "tsx scripts/converters/convert-estat-household-2020.ts",
    "import:household": "tsx scripts/importers/import-household.ts",
    "score:household-v1": "tsx scripts/scoring/score-household-v1.ts --dry-run",
    "fetch:jshis-earthquake-2020": "tsx scripts/fetchers/fetch-jshis-earthquake-2020.ts",
    "convert:jshis-earthquake-2020": "tsx scripts/converters/convert-jshis-earthquake-2020.ts",
    "import:earthquake": "tsx scripts/importers/import-earthquake.ts",
    "score:overall-v2": "tsx scripts/scoring/score-overall-v2.ts --dry-run",
    "score:overall-v2:write": "tsx scripts/scoring/score-overall-v2.ts --output src/data/municipalities.json",
    "analyze:overall-v2-diff": "tsx scripts/analysis/analyze-overall-v2-diff.ts"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5"
  }
}
